{
  "name": "automation-workflow-builder",
  "version": "1.0.0",
  "description": "自动化工作流构建器，设计并执行跨平台自动化流程",
  "author": "automation-tools-dev",
  "license": "MIT-0",
  "engines": {
    "openclaw": ">=1.0.0"
  },
  "triggers": [
    "自动化",
    "工作流",
    "automation",
    "workflow",
    "RPA",
    "流程自动化",
    "定时任务",
    "cron"
  ],
  "capabilities": [
    "exec",
    "read",
    "write",
    "web_fetch",
    "message"
  ],
  "config": {
    "maxConcurrentWorkflows": 5,
    "defaultTimeout": 300,
    "logLevel": "info"
  }
}
